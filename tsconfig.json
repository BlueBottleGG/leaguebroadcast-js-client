{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2022",
    "lib": ["ES2021", "DOM"],
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "resolveJsonModule": true,
    "paths": {
      "#types": ["./types"],
      "#types/*": ["./types/*"]
    },
    "types": [
      "node"
    ],
    "typeRoots": ["node_modules/@types", "./types"]
  },
  "include": [
    "src/**/*",
    "examples/**/*",
    "test/**/*",
    "scripts/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
}
